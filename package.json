{
  "name": "tntstack",
  "version": "1.4.0",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "clean": "turbo run clean",
    "check-types": "turbo check-types",
    "shadcn": "pnpm --filter @workspace/ui shadcn",
    "tauri": "pnpm --filter native tauri",
    "web": "pnpm --filter web",
    "deps:check": "taze -r",
    "deps:update": "taze -r -w -i"
  },
  "devDependencies": {
    "@workspace/eslint-config": "workspace:*",
    "@workspace/typescript-config": "workspace:*",
    "prettier": "^3.8.1",
    "taze": "^19.10.0",
    "turbo": "^2.8.14",
    "typescript": "~5.9.3"
  },
  "packageManager": "pnpm@10.32.0+sha512.9b2634bb3fed5601c33633f2d92593f506270a3963b8c51d2b2d6a828da615ce4e9deebef9614ccebbc13ac8d3c0f9c9ccceb583c69c8578436fa477dbb20d70",
  "engines": {
    "node": ">=20"
  }
}
